# Local dev — copy to .env.local and fill in values (never commit .env.local).
# Restarts Next dev server after changes.

OPENAI_API_KEY=

# Rashi uses inline system instructions in code by default. Set OPENAI_RASHI_PROMPT_ID=pmpt_... to use Playground instead (model must match prompt).
# OPENAI_RASHI_PROMPT_ID=

# OPENAI_RASHI_PROMPT_VARIABLES=true
# OPENAI_RASHI_PROMPT_VERSION=3

# OPENAI_RASHI_REALTIME_MODEL=gpt-realtime-mini

# Realtime voice id (Playground "Martin" → marin)
# OPENAI_RASHI_VOICE=marin
